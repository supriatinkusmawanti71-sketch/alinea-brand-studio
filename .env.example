# Shared
APP_ENV=local
APP_NAME=Brand Agent Studio
LOG_LEVEL=INFO
AUTH_MODE=single_tenant
DEFAULT_WORKSPACE_ID=local-workspace
DEFAULT_ACTOR_ID=local-developer

# Web
NEXT_PUBLIC_API_BASE_URL=/api/v1
API_INTERNAL_URL=http://localhost:8000

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
DATABASE_URL=postgresql://brand_agent:brand_agent@postgres:5432/brand_agent
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Object storage (local MinIO defaults; replace only in private local .env)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=brand-agent-local
S3_SECRET_ACCESS_KEY=brand-agent-local-secret
S3_BUCKET=brand-agent-local
S3_REGION=us-east-1
S3_USE_SSL=false

# Models: fake mode is the shared-development default
TEXT_MODEL_PROVIDER=fake
TEXT_MODEL_NAME=fake-text-v1
TEXT_MODEL_API_KEY=
IMAGE_MODEL_PROVIDER=fake
IMAGE_MODEL_NAME=fake-image-v1
IMAGE_MODEL_API_KEY=

# SiliconFlow (only used when both providers are set to siliconflow)
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_IMAGE_SIZE=1024x1024

# Optional per-Agent model overrides. Leave empty to reuse TEXT_MODEL_NAME/IMAGE_MODEL_NAME.
SILICONFLOW_ART_DIRECTOR_TEXT_MODEL=
SILICONFLOW_LOGO_AGENT_TEXT_MODEL=
SILICONFLOW_IP_DESIGNER_TEXT_MODEL=
SILICONFLOW_DIRECTIONS_IMAGE_MODEL=
SILICONFLOW_LOGO_IMAGE_MODEL=
SILICONFLOW_IP_IMAGE_MODEL=

# OpenRouter (only used when both providers are set to openrouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEXT_MODEL=bytedance-seed/seed-2.0-mini
OPENROUTER_IMAGE_MODEL=bytedance-seed/seedream-4.5
OPENROUTER_IMAGE_SIZE=2048x2048
OPENROUTER_ART_DIRECTOR_TEXT_MODEL=
OPENROUTER_LOGO_AGENT_TEXT_MODEL=
OPENROUTER_IP_DESIGNER_TEXT_MODEL=
OPENROUTER_DIRECTIONS_IMAGE_MODEL=
OPENROUTER_LOGO_IMAGE_MODEL=
OPENROUTER_IP_IMAGE_MODEL=

# OpenAI (only used when both providers are set to openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_ART_DIRECTOR_TEXT_MODEL=
OPENAI_LOGO_AGENT_TEXT_MODEL=
OPENAI_IP_DESIGNER_TEXT_MODEL=
OPENAI_DIRECTIONS_IMAGE_MODEL=
OPENAI_LOGO_IMAGE_MODEL=
OPENAI_IP_IMAGE_MODEL=

# Local service ports (change only when a port is already occupied)
WEB_PORT=3000
API_EXPOSE_PORT=8000
GATEWAY_PORT=8080
POSTGRES_EXPOSE_PORT=5432
REDIS_EXPOSE_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
